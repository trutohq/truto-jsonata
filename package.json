{
  "name": "@truto/truto-jsonata",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "version": "2.0.1",
  "description": "Truto extension of jsonata",
  "repository": "https://github.com/trutohq/truto-jsonata.git",
  "source": "src/index.ts",
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.js",
  "browser": "dist/browser/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/index.d.ts",
        "default": "./dist/browser/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    },
    "./presets/*": {
      "types": "./dist/presets/*.d.ts",
      "browser": "./dist/browser/presets/*.js",
      "require": "./dist/cjs/presets/*.cjs",
      "import": "./dist/esm/presets/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "presets/*": [
        "dist/presets/*.d.ts"
      ]
    }
  },
  "type": "module",
  "license": "MIT",
  "author": "Truto <eng@truto.one>",
  "volta": {
    "node": "22.12.0",
    "yarn": "1.22.22"
  },
  "resolutions": {
    "brace-expansion": "npm:brace-expansion@1.1.12",
    "vite": "npm:vite@6.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20241018.0",
    "@parcel/packager-ts": "2.16.4",
    "@parcel/transformer-typescript-types": "2.16.4",
    "@types/bun": "1.2.19",
    "@types/json2md": "1.5.4",
    "@types/lodash-es": "4.17.12",
    "@types/luxon": "3.4.2",
    "@types/node": "20.14.8",
    "@types/qs": "6.14.0",
    "@types/react": "19.2.14",
    "@types/turndown": "5.0.5",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "eslint": "9.39.2",
    "eslint-config-prettier": "8.5.0",
    "eslint-plugin-prettier": "4.2.1",
    "hyparquet": "1.25.1",
    "parcel": "2.16.4",
    "prettier": "2.8.4",
    "typescript": "5.1.6",
    "vitest": "3.0.9"
  },
  "dependencies": {
    "@json2csv/plainjs": "7.0.6",
    "@langchain/core": "1.1.35",
    "@langchain/textsplitters": "1.0.1",
    "@mixmark-io/domino": "2.2.0",
    "@truto/turndown-plugin-gfm": "1.0.2",
    "dependency-graph": "1.0.0",
    "dice-coefficient": "2.1.1",
    "hyparquet-writer": "0.13.0",
    "json2md": "2.0.1",
    "jsonata": "2.0.6",
    "lodash-es": "4.17.23",
    "luxon": "3.5.0",
    "marked": "14.1.3",
    "marklassian": "1.0.2",
    "md5.js": "1.3.5",
    "mime": "4.0.4",
    "p-map": "7.0.3",
    "p-retry": "6.2.1",
    "qs": "6.15.0",
    "turndown": "7.2.0",
    "vitest-fetch-mock": "0.3.0",
    "xml-js": "1.6.11"
  },
  "scripts": {
    "dev": "parcel watch",
    "build": "rm -rf dist && bun run build.ts",
    "types": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "prepublishOnly": "yarn test && yarn build && yarn types",
    "test": "vitest"
  }
}
